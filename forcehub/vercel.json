{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/api/markets", "destination": "/api/market?kind=markets" },
    { "source": "/api/market-data", "destination": "/api/market?kind=market-data" },
    { "source": "/api/cotacoes", "destination": "/api/market?kind=cotacoes" },
    { "source": "/api/tickers", "destination": "/api/market?kind=tickers" },
    { "source": "/api/cohort", "destination": "/api/users?fn=cohort" },
    { "source": "/api/seed-demo", "destination": "/api/users?fn=seeddemo" }
  ]
}
