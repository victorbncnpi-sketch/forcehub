# Copie para .env.local (dev) ou configure no painel do Vercel (produção).
# NUNCA versione os valores reais — somente este exemplo.

# === IA (escolha UMA) ===
# Opção gratuita (recomendada, sem cartão): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional: sobrescreve o modelo Gemini (padrão: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Opção paga (alternativa): https://console.anthropic.com
# ANTHROPIC_API_KEY=

# === Dados de mercado ===
# Token gratuito da Brapi: https://brapi.dev (cotações WIN/WDO/IBOV)
BRAPI_TOKEN=
