# Copie para .env.local (dev) ou configure no painel do Vercel (produção).
# NUNCA versione os valores reais — somente este exemplo.

# Chave da API Anthropic — usada pelo proxy /api/ai (Conselheiro, scan, notícias)
ANTHROPIC_API_KEY=

# Token da Brapi — usado pelo cron /api/fetch-market (cotações WIN/WDO/IBOV)
BRAPI_TOKEN=

# Segredo que protege o endpoint do cron /api/fetch-market
CRON_SECRET=

# Vercel KV (gerados automaticamente ao criar o banco KV no Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=
